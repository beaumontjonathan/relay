==================================== INPUT ====================================
# Regression test for field-covariance raw response types: the same field is
# selected both directly (User.linked_actor: User — concrete return type) and
# via an abstract interface spread (NodeWithLinkedActor.linked_actor: Actor —
# abstract return type). This exercises the code path where `by_concrete_type`
# and `by_abstract_type` both receive selections, and ensures that untyped
# base_field selections from the abstract path are routed into the known
# concrete bucket when `concrete_type` is available, rather than generating a
# spurious catch-all ExactObject.
fragment FragmentOnNodeWithLinkedActor on NodeWithLinkedActor {
  linked_actor {
    id
  }
}

query MyQuery @raw_response_type {
  me {
    linked_actor {
      name
      canViewerLike
    }
    ...FragmentOnNodeWithLinkedActor
  }
}
